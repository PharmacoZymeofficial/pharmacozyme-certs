# ============================================================
# PharmacoZyme Certificate System — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub!
# ============================================================

# Your deployed app URL (Vercel gives you this after deploy)
# e.g. https://pharmacozyme-certs.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-vercel-app.vercel.app

# Verification portal URL (usually BASE_URL + /verify)
NEXT_PUBLIC_VERIFY_URL=https://your-vercel-app.vercel.app/verify

# ── Firebase Configuration ──────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Email Service (Resend) ──────────────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# ── Google Drive Folder ID ──────────────────────────────────
# The folder ID from your Google Drive URL where PDFs are saved
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ── Google Apps Script ──────────────────────────────────────
# Deploy apps-script.js as a Web App in Google Apps Script
# and paste the deployment URL here
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@pharmacozyme.com
